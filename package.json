{
  "name": "nova-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@nova/db",
    "db:migrate": "turbo run db:migrate --filter=@nova/db",
    "db:seed": "turbo run db:seed --filter=@nova/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "npm@10.5.2",
  "dependencies": {
    "@neondatabase/serverless": "^0.9.5"
  }
}
